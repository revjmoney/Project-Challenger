# Virtual environment
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyz

# Runtime data (generated — not source)
data/challenger_trades.db
data/historical_candles.csv
data/cv_folds.pkl
data/*.log

# Sensitive credentials — NEVER commit these
data/api_keys.json
data/api_keys.txt
data/auth.json
data/.secrets.json

# User preference overrides (optional — contains no secrets but is machine-local)
data/user_settings.json

# Registration flag (generated on first-run — not source)
data/.registered

# Install cache (machine-local — must never be committed or shared)
data/.idata

# Trained model weights (large binaries — regenerated by training.py)
models/

# Temp logs created during testing
data/run.log
data/run_err.log
data/main_test.log
data/main_test_err.log

# Logs (runtime output — may contain local paths or timing data)
logs/
*.log

# Git backup directory (should never be committed)
.git_backup/

# Local-only archive — must never be tracked or pushed
extras/lsys.zip

# OS / editor noise
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
*.code-workspace
